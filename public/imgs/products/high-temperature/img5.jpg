<script>
document.addEventListener('DOMContentLoaded', function () {
    // Select all the elements with class 'wpc-checkbox-item'
    const checkboxItems = document.querySelectorAll('.wpc-checkbox-item');

    checkboxItems.forEach(function(item) {
        // Find the span with class 'wpc-term-count-value' within each checkbox item
        const countValue = item.querySelector('.wpc-term-count-value');
        
        // If the count value is 0, hide the item
        if (countValue && countValue.textContent === '0') {
            item.style.display = 'none';
        }
    });
});
</script>
