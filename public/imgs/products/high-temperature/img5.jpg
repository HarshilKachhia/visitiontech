<script>
document.addEventListener('DOMContentLoaded', function() {
    const filterChips = document.querySelectorAll('.wpc-filter-chip');
    const elementToAdjust = document.querySelector('.elementor-element-914ebef');
    
    // Check if any chip is selected
    if (filterChips.length === 0) {
        elementToAdjust.style.height = '35px';
    } else {
        elementToAdjust.style.height = ''; // Reset to original height if chips are present
    }
});
</script>
