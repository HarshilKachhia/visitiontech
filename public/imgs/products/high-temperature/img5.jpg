<style id='popup-maker-site-inline-css'>
/* Popup Google Fonts */
@import url('//fonts.googleapis.com/css?family=Montserrat:100');

/* Popup Theme 6453: Custom Light Box */
.pum-theme-6453, .pum-theme-light-box { background-color: rgba( 11, 48, 79, 0.55 ) } 
.pum-theme-6453 .pum-container, .pum-theme-light-box .pum-container { padding: 30px; border-radius: 6px; border: 8px none #000000; box-shadow: 0px 0px 30px 0px rgba( 11, 48, 79, 0.13 ); background-color: rgba( 255, 255, 255, 1.00 ) } 
.pum-theme-6453 .pum-title, .pum-theme-light-box .pum-title { color: #000000; text-align: left; text-shadow: 0px 0px 0px rgba( 2, 2, 2, 0.23 ); font-family: inherit; font-weight: 100; font-size: 32px; line-height: 36px } 
.pum-theme-6453 .pum-content, .pum-theme-light-box .pum-content { color: #000000; font-family: inherit; font-weight: 400 } 
.pum-theme-6453 .pum-content + .pum-close, .pum-theme-light-box .pum-content + .pum-close { position: absolute; height: 26px; width: 26px; left: auto; right: -13px; bottom: auto; top: -13px; padding: 0px; color: #ffffff; font-family: Arial; font-weight: 700; font-size: 24px; line-height: 24px; border: 2px solid #ffffff; border-radius: 26px; box-shadow: 0px 0px 15px 1px rgba( 11, 48, 79, 0.75 ); text-shadow: 0px 0px 0px rgba( 0, 0, 0, 0.23 ); background-color: rgba( 10, 10, 10, 1.00 ) } 

/* Popup Theme 3338: Framed Border */
