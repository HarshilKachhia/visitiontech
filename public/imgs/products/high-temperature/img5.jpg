  <div id="google_translate_element_mobile" style="display:none;"></div>

  <script>
  const isMobile = window.innerWidth <= 1024;

  if (!isMobile) {
    // Desktop version (unchanged)
    window.gtranslateSettings = {
      default_language: "en",
      native_language_names: true,
      detect_browser_language: false,
      wrapper_selector: ".gtranslate_wrapper",
    };
    const gtranslateScript = document.createElement("script");
    gtranslateScript.src = "https://cdn.gtranslate.net/widgets/latest/dropdown.js";
    gtranslateScript.defer = true;
    document.head.appendChild(gtranslateScript);
  }

  if (isMobile) {
    // Show dropdown
    const langSwitcherWrapper = document.querySelector(".mobile_lang_switcher");
    if (langSwitcherWrapper) {
      langSwitcherWrapper.style.display = "block";
    }

    // Load Google Translate API
    const gTranslateScript = document.createElement("script");
    gTranslateScript.src = "//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit";
    document.head.appendChild(gTranslateScript);

    window.googleTranslateElementInit = function () {
      new google.translate.TranslateElement({
        pageLanguage: 'en',
        includedLanguages: 'af,sq,am,ar,hy,az,eu,be,bn,bs,bg,ca,ceb,zh-CN,zh-TW,co,hr,cs,da,nl,en,eo,et,fi,fr,fy,gl,ka,de,el,gu,ht,ha,haw,he,hi,hmn,hu,is,ig,id,ga,it,ja,jv,kn,kk,km,rw,ko,ku,ky,lo,la,lv,lt,lb,mk,mg,ms,ml,mt,mi,mr,mn,my,ne,no,ny,or,ps,fa,pl,pt,pa,ro,ru,sm,gd,sr,st,sn,sd,si,sk,sl,so,es,su,sw,sv,tl,tg,ta,tt,te,th,tr,tk,uk,ur,ug,uz,vi,cy,xh,yi,yo,zu',
        autoDisplay: false,
        layout: google.translate.TranslateElement.InlineLayout.SIMPLE
      }, 'google_translate_element_mobile');

      initLangSwitcher(); // initialize after Translate loads
    };

    function initLangSwitcher() {
      const langSelect = document.getElementById("langSwitcherMobile");
      if (!langSelect) return;

      // Read saved language from cookie
      const match = document.cookie.match(/googtrans=\/en\/([a-z\-]+)/i);
      const savedLang = match ? match[1] : "en";

      // Update dropdown to reflect saved language
      langSelect.value = savedLang;

      langSelect.addEventListener("change", function () {
        const lang = this.value;

        // Set cookies
        const expires = new Date();
        expires.setFullYear(expires.getFullYear() + 1);
        const expiresStr = `expires=${expires.toUTCString()};path=/`;

        document.cookie = `googtrans=/en/${lang};${expiresStr}`;
        document.cookie = `googtrans=/en/${lang};${expiresStr};domain=${location.hostname}`;

        // Save scroll position
        sessionStorage.setItem("scrollPosX", window.scrollX);
        sessionStorage.setItem("scrollPosY", window.scrollY);

        // Reload to apply translation
        location.reload();
      });

      // Auto-translate if a non-English language is stored in cookie
      if (savedLang && savedLang !== "en") {
        const interval = setInterval(() => {
          const googleCombo = document.querySelector(".goog-te-combo");
          if (googleCombo && googleCombo.length > 0) {
            googleCombo.value = savedLang;
            googleCombo.dispatchEvent(new Event("change"));
            clearInterval(interval);
          }
        }, 100);
      }
    }

    // Rebind if content changes dynamically
    const observer = new MutationObserver(() => {
      initLangSwitcher();
    });
    observer.observe(document.body, { childList: true, subtree: true });
  }
</script>

<style>
  /* Hide the top Google Translate frame */
  .goog-te-banner-frame.skiptranslate,
  body > .skiptranslate {
    display: none !important;
  }
  body {
    top: 0px !important;
  }
</style>




  <script>
  document.addEventListener("DOMContentLoaded", function () {
    const btn = document.getElementById("toggleBtn");
    const menu = document.getElementById("main-menu");

    window.toggleMenu = function () {
      // Toggle open class
      btn.classList.toggle("open");
      menu.classList.toggle("open");

      // Toggle menu display
      if (menu.style.display === "block") {
        menu.style.display = "none";
      } else {
        menu.style.display = "block";
      }

      // Toggle icon
      btn.innerHTML = btn.classList.contains("open") ? "✕" : "☰";
    };

    // Toggle submenu visibility
    window.toggleSubMenu = function (id) {
      const submenumob = document.getElementById(id);
      submenumob.style.display = submenumob.style.display === "block" ? "none" : "block";
    };
  });
</script>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const searchIcon = document.getElementById('search-icon');
      const searchBar = document.getElementById('search-bar');

      searchIcon.addEventListener('click', (event) => {
        event.stopPropagation();

        // Toggle `hidden` class and ensure `visible` is handled correctly
        if (searchBar.classList.contains('hidden')) {
          searchBar.classList.remove('hidden');
          searchBar.classList.add('visible');
        } else {
          searchBar.classList.remove('visible');
          searchBar.classList.add('hidden');
        }
      });

      document.addEventListener('click', (event) => {
        if (!searchBar.contains(event.target) && !searchIcon.contains(event.target)) {
          searchBar.classList.add('hidden');
          searchBar.classList.remove('visible');
        }
      });
    });

  </script>


<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchIconMobile = document.getElementById('search-icon-mobile');
    const searchBarMobile = document.getElementById('search-bar-mobile');

    if (searchIconMobile && searchBarMobile) {
      ['click', 'touchstart'].forEach(eventType => {
        searchIconMobile.addEventListener(eventType, (event) => {
          event.stopPropagation();
          searchBarMobile.classList.toggle('hidden');
          searchBarMobile.classList.toggle('visible');
        });
      });

      document.addEventListener('click', (event) => {
        if (!searchBarMobile.contains(event.target) && !searchIconMobile.contains(event.target)) {
          searchBarMobile.classList.add('hidden');
          searchBarMobile.classList.remove('visible');
        }
      });
    }
  });
</script>


