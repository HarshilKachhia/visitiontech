<script>
document.addEventListener("DOMContentLoaded", function () {
    // Select all filter headers
    const filterHeaders = document.querySelectorAll('.wpc-filter-header');
    const collapseAllChip = document.querySelector('.clearAllChip.collapseAllChip');

    function toggleAll(expand) {
        filterHeaders.forEach(header => {
            const arrowUp = header.querySelector('.arrow.up');
            const arrowDown = header.querySelector('.arrow.down');
            const filterContent = header.parentElement.querySelector('.wpc-filter-content');

            if (expand) {
                arrowUp.style.display = 'none'; // Hide arrow up
                arrowDown.style.display = 'inline'; // Show arrow down
                if (filterContent) {
                    filterContent.style.display = 'block'; // Show the content section
                }
            } else {
                arrowUp.style.display = 'inline'; // Show arrow up
                arrowDown.style.display = 'none'; // Hide arrow down
                if (filterContent) {
                    filterContent.style.display = 'none'; // Hide the content section
                }
            }
        });
    }

    filterHeaders.forEach(header => {
        header.addEventListener('click', function () {
            // Find the related arrows and content within the same section
            const arrowUp = header.querySelector('.arrow.up');
            const arrowDown = header.querySelector('.arrow.down');
            const filterContent = header.parentElement.querySelector('.wpc-filter-content');

            // Toggle visibility of arrows and content
            if (arrowUp.style.display === 'none') {
                arrowUp.style.display = 'inline'; // Show arrow up
                arrowDown.style.display = 'none'; // Hide arrow down
                if (filterContent) {
                    filterContent.style.display = 'none'; // Hide the content section
                }
            } else {
                arrowUp.style.display = 'none'; // Hide arrow up
                arrowDown.style.display = 'inline'; // Show arrow down
                if (filterContent) {
                    filterContent.style.display = 'block'; // Show the content section
                }
            }
        });
    });

    if (collapseAllChip) {
        collapseAllChip.addEventListener('click', function () {
            if (collapseAllChip.textContent.trim() === 'Collapse All') {
                toggleAll(false); // Collapse all sections
                collapseAllChip.textContent = 'Expand All';
            } else {
                toggleAll(true); // Expand all sections
                collapseAllChip.textContent = 'Collapse All';
            }
        });
    }
});
</script>
