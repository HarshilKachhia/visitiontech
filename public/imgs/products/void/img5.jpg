		<style id="wp-custom-css">
			/* GeneratePress Site CSS */ /* Box shadow */
.box-shadow {
	box-shadow: 0px 0px 35px -13px rgba(0,36,72,0.4);
}

/* Sidebars*/
@media (max-width: 768px) {
	.widget-area.is-right-sidebar {
	margin-top: 80px;
	}
} /* End GeneratePress Site CSS */

/* End GeneratePress Site CSS */

/* ------------------- */
/* WhatsApp Chat Button Start */
.whatsapp-float {
  position: fixed;
  bottom: 80px;
  right: 20px;
  background-color: #25D366;
  color: white;
  padding: 12px 20px;
  border-radius: 50px;
  font-size: 16px;
  font-weight: bold;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  text-decoration: none;
  z-index: 9999;
  transition: background-color 0.3s ease;
}
.whatsapp-float:hover {
  background-color: #1ebe5d;
}
@media (max-width: 768px) {
  .whatsapp-float {
    font-size: 14px;
    padding: 10px 16px;
    bottom: 15px;
    right: 15px;
  }
}
/* WhatsApp Chat Button End */
/* ------------------- */

/* Enable collapsible FAQ for RankMath in GeneratePress */
.wp-block-rank-math-faq .wp-block-rank-math-faq-item {
  cursor: pointer;
  border: 1px solid #ddd;
  padding: 12px;
  border-radius: 6px;
  margin-bottom: 10px;
  background-color: #f9f9f9;
}

.wp-block-rank-math-faq .rank-math-answer {
  display: none;
  margin-top: 8px;
  color: #333;
}

.wp-block-rank-math-faq .faq-open .rank-math-answer {
  display: block;
}

.wp-block-rank-math-faq .rank-math-question::after {
  content: " ＋";
  float: right;
  font-weight: bold;
  color: #888;
}

.wp-block-rank-math-faq .faq-open .rank-math-question::after {
  content: " －";
  color: #444;
}

/* 缩小语言切换框宽度与字体 */
.gtranslate_wrapper {
  font-size: 13px !important;
  max-width: 100px !important;
}

.gtranslate_wrapper select {
  padding: 2px 4px !important;
  height: 28px !important;
  font-size: 13px !important;
  line-height: 1.2em;
}

/* 缩小下拉列表内容区域 */
.gtranslate_wrapper .switcher div.option {
  padding: 4px 6px !important;
  font-size: 13px !important;
}

/* 限制最大高度（防止下拉太长） */
.gtranslate_wrapper .switcher {
  max-height: 200px;
  overflow-y: auto;
}

/* 调整旗帜图标大小 */
.gtranslate_wrapper img {
  width: 16px !important;
  height: auto;
  margin-right: 4px;
}


.simple-author-box {
    position: fixed !important;       /* 固定位置 */
    right: 20px !important;           /* 距右 20px */
    top: 50% !important;              /* 垂直居中 */
    transform: translateY(-50%) !important; /* 精准居中 */
    width: 250px !important;          /* 宽度 */
    z-index: 9999 !important;         /* 顶层显示 */
}

/* 手机端隐藏 */
@media screen and (max-width: 1024px) {
    .simple-author-box {
        display: none !important;
    }
}
/* ================================
   EcoSecurityTape - Global RankMath FAQ Style
   适用于所有 RankMath FAQ block
   ================================ */

/* FAQ 容器整体间距 */
.rank-math-block {
    margin: 24px 0;
}

/* 问题块样式 */
.rank-math-block .rank-math-question {
    position: relative;
    margin: 0 0 8px;
    padding: 18px 56px 18px 24px; /* 左文案，右侧留位置给 + 号 */
    background: #ECF5FF;          /* 背景颜色 */
    border-radius: 12px;          /* 圆角 */
    border: 1px solid #d6e8ff;
    color: #2B78CA;               /* 标题字体颜色 */
    font-weight: 700;
    font-size: 20px;
    cursor: pointer;
    line-height: 1.35;
    transition:
        background-color 0.2s ease,
        box-shadow 0.2s ease,
        transform 0.15s ease;
}

/* 悬停效果：轻微浮起 + 阴影 */
.rank-math-block .rank-math-question:hover {
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.06);
    transform: translateY(-1px);
}

/* 右侧的 + / - 图标 */
.rank-math-block .rank-math-question::after {
    content: "+";
    position: absolute;
    right: 22px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 24px;
    font-weight: 700;
    color: #2B78CA;
    transition: transform 0.2s ease;
}

/* 展开状态：背景稍微加深，图标变 - 并轻微旋转 */
.rank-math-block .rank-math-question.active {
    background: #dfeeff;
}

.rank-math-block .rank-math-question.active::after {
    content: "-";
    transform: translateY(-50%) rotate(180deg);
}

/* 答案块：默认隐藏，由 JS 控制 active 时显示 */
.rank-math-block .rank-math-answer {
    display: none;
    padding: 18px 26px 22px;
    margin: 0 0 16px;
    background: #ffffff;
    border-left: 3px solid #2B78CA;
    border-radius: 0 0 12px 12px;
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.04);
    font-size: 16px;
    line-height: 1.6;
}

/* 问题被激活时，紧挨着的那个答案展开
   （依赖结构：question 下面紧跟 answer） */
.rank-math-block .rank-math-question.active + .rank-math-answer {
    display: block;
}

/* 全站浅蓝色区块（light-section）统一上下间距 */
.light-section {
    padding-top: 15px !important;
    padding-bottom: 15px !important;
    padding-left: 40px !important;
    padding-right: 40px !important;
    border-radius: 6px; /* 可选 */
    margin-top: 20px !important;
    margin-bottom: 20px !important;
}

/* 让标题与正文的间距更紧凑 */
.light-section h2,
.light-section h1 {
    margin-bottom: 10px !important;
}

@media (max-width: 768px) {
    .light-section {
        margin-top: 10px !important;
    }
}

}



		</style>
		</head>

