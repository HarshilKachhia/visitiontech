<script>document.addEventListener("DOMContentLoaded", function () {
  const questions = document.querySelectorAll('.rank-math-question');
  questions.forEach(q => {
    q.addEventListener('click', () => {
      const parent = q.closest('.wp-block-rank-math-faq-item');
      if (parent) {
        parent.classList.toggle('faq-open');
      }
    });
  });
});
</script><link rel="icon" href="https://ecosecuritytape.com/wp-content/uploads/2025/02/cropped-ECOSECURITYTAPE-Logo-Twitter-Profile-Picture-800x800-1-3-32x32.png" sizes="32x32" />
