    ddConfig.beforeSend = function(event, context) {
        if (event.http && event.http.status_code == 0) {
            var ignorePattern = /https:\/\/.*\.clarity\.ms/;
            if (context.isAborted || (event.http.url && ignorePattern.test(event.http.url))) {
