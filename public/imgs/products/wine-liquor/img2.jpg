            <option value="Beauty & Cosmetic">Beauty & Cosmetic</option>
            <option value="Retail & e-Commerce">Retail & e-Commerce</option>
            <option value="Automotive">Automotive</option>
            <option value="Nutraceuticals">Nutraceuticals</option>
            <option value="Chemical & Industrial">Chemical & Industrial</option>
            <option value="Wine and Spirits">Wine and Spirits</option>
            <option value="Logistics">Logistics</option>
            <option value="Agriculture">Agriculture</option>
            <option value="Electronics">Electronics</option>
            <option value="Other">Other</option>
        </select>
        <div class="error-message" id="industryError"></div>
    </div>
    <div class="form-group">
        <label for="message">Your Requirements*</label>
        <textarea id="message" name="message" required></textarea>
        <div class="error-message" id="messageError"></div>
    </div>
    <div id="formStatus" class="form-status"></div>
    <button type="submit" id="submitBtn" class="cta-button">
        <span class="btn-text">Get a Quote!</span>
        <span class="btn-loader" style="display: none;">
            <div class="spinner"></div>
        </span>
        <span class="btn-success" style="display: none;">✅</span>
    </button>
</form>


<script>
    // Phone input validation - only allow numbers, spaces, and plus sign
    function validatePhoneInput(event) {
        const char = String.fromCharCode(event.which);
        const allowedChars = /[0-9+\s]/;

        if (!allowedChars.test(char)) {
            event.preventDefault();
            return false;
        }
        return true;
    }

    // Format phone input to ensure proper formatting
    function formatPhoneInput(input) {
        let value = input.value;

        // Remove any characters that aren't numbers, spaces, or plus sign
        value = value.replace(/[^0-9+\s]/g, '');

        // Ensure only one plus sign at the beginning
        const plusCount = (value.match(/\+/g) || []).length;
        if (plusCount > 1) {
            value = value.replace(/\+/g, '');
            value = '+' + value;
        }

        // Limit consecutive spaces
        value = value.replace(/\s+/g, ' ');

        input.value = value;
    }

    // Set page URL when page loads
    document.addEventListener('DOMContentLoaded', function() {
        const pageUrlField = document.getElementById('pageUrl');
        const currentUrl = window.location.href;
        pageUrlField.value = currentUrl;
        console.log('Page URL set to:', currentUrl);
        console.log('Hidden field value:', pageUrlField.value);
    });
    
    // Form submission handler
    function handleSubmit(event) {
        event.preventDefault();

        // Clear previous error messages
        document.querySelectorAll('.error-message').forEach(el => el.style.display = 'none');
        document.getElementById('formStatus').style.display = 'none';

        // Get form data
        const formData = new FormData(event.target);

        // Validate form data
        let isValid = true;

        // Name validation
        const name = formData.get('name');
        if (!/^[A-Za-z ]+$/.test(name)) {
            document.getElementById('nameError').textContent = 'Please enter only letters and spaces';
            document.getElementById('nameError').style.display = 'block';
            isValid = false;
        }

        // Phone validation - allow numbers, spaces, and plus sign
        const phone = formData.get('phone');
        const phoneDigits = phone.replace(/[^0-9]/g, ''); // Remove all non-digits for length check
        if (!/^[+\s0-9]+$/.test(phone) || phoneDigits.length < 10 || phoneDigits.length > 15) {
            document.getElementById('phoneError').textContent = 'Please enter a valid phone number (10-15 digits with country code)';
            document.getElementById('phoneError').style.display = 'block';
            isValid = false;
        }

        // Email validation
        const email = formData.get('email');
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
            document.getElementById('emailError').textContent = 'Please enter a valid email address';
            document.getElementById('emailError').style.display = 'block';
            isValid = false;
        }

        // Industry validation
        const industry = formData.get('industry');
        if (!industry) {
            document.getElementById('industryError').textContent = 'Please select an industry';
            document.getElementById('industryError').style.display = 'block';
            isValid = false;
        }

        // Message validation
        const message = formData.get('message');
        if (!message.trim()) {
            document.getElementById('messageError').textContent = 'Please enter your requirements';
            document.getElementById('messageError').style.display = 'block';
            isValid = false;
        }

        if (!isValid) {
            return false;
        }

        // Show loader and disable button
        const submitBtn = document.getElementById('submitBtn');
        const btnText = submitBtn.querySelector('.btn-text');
        const btnLoader = submitBtn.querySelector('.btn-loader');
        const btnSuccess = submitBtn.querySelector('.btn-success');

        btnText.style.display = 'none';
        btnLoader.style.display = 'inline-block';
        submitBtn.disabled = true;

        // Verify page URL is in form data (it should already be there from the hidden field)
        const currentPageUrl = window.location.href;
        console.log('Form submission - Page URL being sent:', currentPageUrl);
        console.log('Form data entries:');
        for (let [key, value] of formData.entries()) {
            console.log(key + ':', value);
        }
        
        // Submit form via AJAX
        fetch('mailer/contact-form-handler.php', {
            method: 'POST',
            body: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
            .then(response => response.json())
            .then(data => {
                const statusDiv = document.getElementById('formStatus');
                statusDiv.style.display = 'block';

                if (data.status === 'success') {
                    // Hide loader and show success tick
                    btnLoader.style.display = 'none';
                    btnSuccess.style.display = 'inline-block';

                    statusDiv.className = 'form-status success';
                    statusDiv.textContent = data.message;
                    document.getElementById('contactForm').reset();

                    // Redirect to thank you page after showing success tick
                    setTimeout(() => {
                        window.location.href = data.redirect || 'thank-you.php';
                    }, 2000);
                } else {
                    // Hide loader and show original button text
                    btnLoader.style.display = 'none';
                    btnText.style.display = 'inline-block';
                    submitBtn.disabled = false;

                    statusDiv.className = 'form-status error';
                    if (data.errors) {
                        statusDiv.textContent = data.message + '\n' + data.errors.join('\n');
                    } else {
                        statusDiv.textContent = data.message;
                    }
                }
            })
            .catch(error => {
                // Hide loader and show original button text
                btnLoader.style.display = 'none';
                btnText.style.display = 'inline-block';
                submitBtn.disabled = false;

                const statusDiv = document.getElementById('formStatus');
                statusDiv.style.display = 'block';
                statusDiv.className = 'form-status error';
                statusDiv.textContent = 'An error occurred. Please try again later.';
                console.error('Error:', error);
            });

        return false;
    }
</script>              <!-- Place this script before the closing </body> tag -->
