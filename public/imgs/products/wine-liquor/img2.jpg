      <script>
        const hamburger = document.querySelector(".hamburger");
        const navLinks = document.querySelector(".nav-links");
        const links = document.querySelectorAll(".nav-links li");
        const productDropdown = document.querySelector(".dropdown");

        hamburger?.addEventListener("click", () => {
          //Animate Links
          navLinks.classList.toggle("open");
          links.forEach((link) => {
            link.classList.toggle("fade");
          });
          //Hamburger Animation
          hamburger.classList.toggle("toggle");
        });

        productDropdown?.addEventListener("click", () => {
          productDropdown.classList.toggle("open");
          // Close other dropdowns if needed
          links.forEach((link) => {
            if (link !== productDropdown) {
              link.classList.remove("open");
            }
          });
        });

        document
          .getElementsByClassName("indust-dropdown-link")[0]
          ?.addEventListener("click", () => {
            document
              .getElementsByClassName("indust-dropdown")[0]
              .classList.toggle("dfade");
            document
              .getElementsByClassName("indust-dropdown")[0]
              .classList.toggle("dopen");
          });
      </script>

