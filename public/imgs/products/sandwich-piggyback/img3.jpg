/* --- CONTACT FORM CSS (31/May/2025) --- */
.form-row {margin-bottom: 15px;}
.form-row p {display: flex; width: 100%; max-width: 100%; justify-content: space-between;}
.form-row label {flex: 1; font-weight: 500!important;}
.form-row.block-50 label {width: 32%; max-width: 32%;}
.form-row label span {margin-top: 10px;}

/* --- Responsive ---- */
