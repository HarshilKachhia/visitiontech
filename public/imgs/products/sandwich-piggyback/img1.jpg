})(window,document,'script','dataLayer','GTM-TSFQ3RK');</script> <div id="cookie-consent-banner" role="dialog" aria-modal="true" aria-labelledby="cookie-banner-heading"><h3 id="cookie-banner-heading">Cookie Notice</h3><p>We use cookies to improve your experience, analyse traffic, and support marketing. See our <a href="/privacy-policy/">Privacy Policy</a> for details.</p><div class="cookie-buttons">
<button class="accept-all" onclick="pidAcceptAllCookies()">Accept All</button>
<button class="decline-all" onclick="pidDeclineAllCookies()">Decline All</button>
<button class="manage" onclick="pidManageCookies()">Manage Preferences</button></div></div><div id="cookie-modal-overlay" onclick="pidClosePreferencesModal()" role="presentation"></div><div id="cookie-preferences-modal" role="dialog" aria-modal="true" aria-labelledby="cookie-modal-heading"><h3 id="cookie-modal-heading">Cookie Preferences</h3><div class="cookie-category"><h4>Essential Cookies</h4><p>These cookies are necessary for the website to function and cannot be switched off. They are usually set in response to actions you take, such as filling in forms or setting your preferences.</p><div class="cookie-toggle">
<span>Always Active</span><div class="toggle-switch always-on" aria-label="Essential cookies — always active"></div></div></div><div class="cookie-category"><h4>Analytics Cookies</h4><p>These cookies help us understand how visitors interact with our website, allowing us to improve the experience over time. We use Google Analytics.</p><div class="cookie-toggle">
<span>Google Analytics</span><div class="toggle-switch" id="analytics-toggle" onclick="pidToggleSwitch(this)" role="switch" aria-checked="false" aria-label="Toggle analytics cookies"></div></div></div><div class="cookie-category"><h4>Marketing Cookies</h4><p>These cookies are used to show you relevant advertisements on other websites and to measure the effectiveness of our advertising campaigns. We use Google Ads.</p><div class="cookie-toggle">
<span>Google Ads</span><div class="toggle-switch" id="marketing-toggle" onclick="pidToggleSwitch(this)" role="switch" aria-checked="false" aria-label="Toggle marketing cookies"></div></div></div><div class="modal-buttons">
<button class="save-preferences" onclick="pidSavePreferences()">Save Preferences</button>
<button class="close-modal" onclick="pidClosePreferencesModal()">Cancel</button></div></div> <script>(function() {
	'use strict';

	var CONSENT_KEY   = 'pid-cookie-consent-state';
	var CONSENT_DATE  = 'pid-cookie-consent-date';
	var CONSENT_VER   = 'pid-cookie-consent-version';
	var BANNER_VER    = '1.0'; // Bump this to re-prompt all users after policy changes

	// ----------------------------------------------------------
	// Boot: show banner or reapply saved consent
	// ----------------------------------------------------------
	document.addEventListener('DOMContentLoaded', function () {
		var savedVersion = localStorage.getItem(CONSENT_VER);
		var savedState   = localStorage.getItem(CONSENT_KEY);

		if (!savedState || savedVersion !== BANNER_VER) {
			// No consent recorded, or policy has changed — show banner
			setTimeout(function () {
				var banner = document.getElementById('cookie-consent-banner');
				if (banner) {
					banner.style.display = 'block';
					banner.classList.add('is-visible');
				}
			}, 800);
		} else {
			// Re-apply stored consent so GTM tags fire correctly on subsequent pages
			var parsed = safeParseJSON(savedState);
			if (parsed && typeof gtag === 'function') {
				gtag('consent', 'update', parsed);
			}
		}
	});

	// ----------------------------------------------------------
	// Accept All
	// ----------------------------------------------------------
	window.pidAcceptAllCookies = function () {
		var update = {
			'ad_storage':          'granted',
			'ad_user_data':        'granted',
			'ad_personalization':  'granted',
			'analytics_storage':   'granted'
		};
		applyAndStore(update);
		pidHideBanner();
		// Reload so GTM fires newly-consented tags on this page
		setTimeout(function () { window.location.reload(); }, 500);
	};

	// ----------------------------------------------------------
	// Decline All
	// ----------------------------------------------------------
	window.pidDeclineAllCookies = function () {
		var update = {
			'ad_storage':          'denied',
			'ad_user_data':        'denied',
			'ad_personalization':  'denied',
			'analytics_storage':   'denied'
		};
		applyAndStore(update);
		pidHideBanner();
		// No reload needed — default state already denied, nothing new fires
	};

	// ----------------------------------------------------------
	// Open Preferences Modal
	// ----------------------------------------------------------
	window.pidManageCookies = function () {
		var overlay = document.getElementById('cookie-modal-overlay');
		var modal   = document.getElementById('cookie-preferences-modal');
		if (!overlay || !modal) return;

		overlay.style.display = 'block';
		modal.style.display   = 'block';

		// Populate toggles from stored prefs
		var saved = safeParseJSON(localStorage.getItem(CONSENT_KEY));
		var analyticsToggle  = document.getElementById('analytics-toggle');
		var marketingToggle  = document.getElementById('marketing-toggle');

		if (saved && analyticsToggle) {
			setToggle(analyticsToggle, saved.analytics_storage === 'granted');
		}
		if (saved && marketingToggle) {
			setToggle(marketingToggle, saved.ad_storage === 'granted');
		}
	};

	// ----------------------------------------------------------
	// Toggle switch click handler
	// ----------------------------------------------------------
	window.pidToggleSwitch = function (el) {
		var isActive = el.classList.contains('active');
		setToggle(el, !isActive);
	};

	// ----------------------------------------------------------
	// Save Preferences from modal
	// ----------------------------------------------------------
	window.pidSavePreferences = function () {
		var analyticsOn  = document.getElementById('analytics-toggle').classList.contains('active');
		var marketingOn  = document.getElementById('marketing-toggle').classList.contains('active');

		var update = {
			'ad_storage':          marketingOn ? 'granted' : 'denied',
			'ad_user_data':        marketingOn ? 'granted' : 'denied',
			'ad_personalization':  marketingOn ? 'granted' : 'denied',
			'analytics_storage':   analyticsOn ? 'granted' : 'denied'
		};

		applyAndStore(update);
		pidClosePreferencesModal();
		pidHideBanner();

		// Reload only if at least one category was granted (so newly-consented tags fire)
		if (analyticsOn || marketingOn) {
			setTimeout(function () { window.location.reload(); }, 500);
		}
	};

	// ----------------------------------------------------------
	// Close modal
	// ----------------------------------------------------------
	window.pidClosePreferencesModal = function () {
		var overlay = document.getElementById('cookie-modal-overlay');
		var modal   = document.getElementById('cookie-preferences-modal');
		if (overlay) overlay.style.display = 'none';
		if (modal)   modal.style.display   = 'none';
	};

	// ----------------------------------------------------------
	// Hide banner with slide-down animation
	// ----------------------------------------------------------
	window.pidHideBanner = function () {
		var banner = document.getElementById('cookie-consent-banner');
		if (!banner) return;
		banner.style.transition = 'transform 0.4s ease, opacity 0.4s ease';
		banner.style.transform  = 'translateY(100px)';
		banner.style.opacity    = '0';
		setTimeout(function () { banner.style.display = 'none'; }, 420);
	};

	// ----------------------------------------------------------
	// Re-open banner (call from footer "Cookie Settings" link)
	// window.pidReopenCookieConsent();
	// ----------------------------------------------------------
	window.pidReopenCookieConsent = function () {
		localStorage.removeItem(CONSENT_KEY);
		localStorage.removeItem(CONSENT_DATE);
		localStorage.removeItem(CONSENT_VER);
		var banner = document.getElementById('cookie-consent-banner');
		if (banner) {
			banner.style.transform  = '';
			banner.style.opacity    = '';
			banner.style.display    = 'block';
			banner.classList.add('is-visible');
		}
	};

	// ----------------------------------------------------------
	// Helpers
	// ----------------------------------------------------------
	function applyAndStore(consentObj) {
		if (typeof gtag === 'function') {
			gtag('consent', 'update', consentObj);
		}
		localStorage.setItem(CONSENT_KEY,  JSON.stringify(consentObj));
		localStorage.setItem(CONSENT_DATE, new Date().toISOString());
		localStorage.setItem(CONSENT_VER,  BANNER_VER);
	}

	function setToggle(el, active) {
		if (active) {
			el.classList.add('active');
			el.setAttribute('aria-checked', 'true');
		} else {
			el.classList.remove('active');
			el.setAttribute('aria-checked', 'false');
		}
	}

	function safeParseJSON(str) {
		try { return JSON.parse(str); } catch (e) { return null; }
	}

})();</script><script id="google_gtagjs" src="https://www.googletagmanager.com/gtag/js?id=G-8QVMBGMTDP" async></script> <script id="google_gtagjs-inline">window.dataLayer = window.dataLayer || [];function gtag(){dataLayer.push(arguments);}gtag('js', new Date());gtag('config', 'G-8QVMBGMTDP', {} );</script> <link rel="icon" href="https://pid-labelling.co.uk/wp-content/uploads/cropped-favicon-1-32x32.gif" sizes="32x32" /><link rel="icon" href="https://pid-labelling.co.uk/wp-content/uploads/cropped-favicon-1-192x192.gif" sizes="192x192" /><link rel="apple-touch-icon" href="https://pid-labelling.co.uk/wp-content/uploads/cropped-favicon-1-180x180.gif" /><meta name="msapplication-TileImage" content="https://pid-labelling.co.uk/wp-content/uploads/cropped-favicon-1-270x270.gif" /></head><body class="error404 wp-custom-logo wp-embed-responsive wp-theme-kadence wp-child-theme-kadence-child theme-kadence woocommerce-no-js hfeed footer-on-bottom hide-focus-outline link-style-standard content-title-style-normal content-width-normal content-style-boxed content-vertical-padding-show non-transparent-header mobile-non-transparent-header"><noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TSFQ3RK"
